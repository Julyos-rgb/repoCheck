# ============================================
# RepoCheck 环境变量配置示例
# 复制此文件为 .env.local 并填入你的密钥
# cp .env.example .env.local
# ============================================

# ---------- AI 配置 ----------

# AI 提供商（可选值: openai, anthropic, deepseek, qwen, glm, moonshot, minimax）
# 不配置时默认使用 openai
AI_PROVIDER=openai

# AI 模型名称（可选，不配置则使用各提供商的默认模型）
# AI_MODEL=gpt-4o-mini

# 自定义 Base URL（可选，覆盖提供商默认的 baseURL）
# 可用于接入各种兼容接口，例如智谱的 Anthropic 兼容接口：
# AI_BASE_URL=https://open.bigmodel.cn/api/anthropic

# API 超时时间，单位毫秒（可选，默认 30000 即 30 秒）
# AI_TIMEOUT_MS=30000

# ---------- GitHub 配置 ----------

# GitHub Token（可选，用于提升 GitHub API 速率限制：60次/小时 → 5000次/小时）
# 在 https://github.com/settings/tokens 创建，无需任何权限
# GITHUB_TOKEN=ghp_your_github_token_here

# ---------- AI 提供商 API Key（按需配置） ----------

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 通义千问 Qwen
QWEN_API_KEY=your_qwen_api_key_here

# 智谱 GLM
GLM_API_KEY=your_glm_api_key_here

# Moonshot
MOONSHOT_API_KEY=your_moonshot_api_key_here

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key_here
